#include <gtest/gtest.h>
#include <queue>
#include <string>

// ==================== ТЕСТЫ ДЛЯ std::queue ====================
class QueueTest : public ::testing::Test {
protected:
    void SetUp() override {
        // Инициализация перед каждым тестом
    }
    
    void TearDown() override {
        // Очистка после каждого теста
    }
};

TEST_F(QueueTest, NewQueueIsEmpty) {
    std::queue<int> queue;
    EXPECT_TRUE(queue.empty());
    EXPECT_EQ(queue.size(), 0);
}

TEST_F(QueueTest, PushIncreasesSize) {
    std::queue<int> queue;
    queue.push(10);
    EXPECT_EQ(queue.size(), 1);
    EXPECT_FALSE(queue.empty());
    
    queue.push(20);
    EXPECT_EQ(queue.size(), 2);
}

TEST_F(QueueTest, PopDecreasesSize) {
    std::queue<int> queue;
    queue.push(10);
    queue.push(20);
    
    queue.pop();
    EXPECT_EQ(queue.size(), 1);
    
    queue.pop();
    EXPECT_EQ(queue.size(), 0);
    EXPECT_TRUE(queue.empty());
}

TEST_F(QueueTest, FrontReturnsFirstElement) {
    std::queue<int> queue;
    queue.push(10);
    queue.push(20);
    queue.push(30);
    
    EXPECT_EQ(queue.front(), 10);
    queue.pop();
    EXPECT_EQ(queue.front(), 20);
    queue.pop();
    EXPECT_EQ(queue.front(), 30);
}

TEST_F(QueueTest, BackReturnsLastElement) {
    std::queue<int> queue;
    queue.push(10);
    EXPECT_EQ(queue.back(), 10);
    
    queue.push(20);
    EXPECT_EQ(queue.back(), 20);
    
    queue.push(30);
    EXPECT_EQ(queue.back(), 30);
}

TEST_F(QueueTest, PopFromEmptyQueueIsUndefinedButWeCanCheck) {
    std::queue<int> queue;
    EXPECT_TRUE(queue.empty());
    // Внимание: pop() на пустой очереди - неопределенное поведение
    // Мы просто проверяем, что мы не вызываем pop на пустой очереди
    if (!queue.empty()) {
        queue.pop();
    }
    EXPECT_TRUE(queue.empty());
}
